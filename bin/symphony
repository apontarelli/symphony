#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  symphony
  symphony setup <init|check|preview> [options]
  symphony setup migrate --repo <path> [--name <lowercase-slug>] [--config-root <path>] [--apply]
  symphony list [--repo <path>] [--config-root <path>] [--no-env-file]
  symphony run <saved-name> [--preview] [--config-root <path>] [--yes]
  symphony run [ISSUE-ID ...] [--repo <path>] [--save <lowercase-slug>] [--preview] [--yes]
  symphony run --workflow /path/to/symphony.runtime.yml [options]

Commands:
  no arguments                 Open the saved-workflow picker in a repo with symphony.yml.
  setup                        Create, validate, or preview durable repo setup.
  list                         List saved workflows for the active repo without starting Symphony.
  run <saved-name>             Preview, confirm, and start a saved workflow.
  run --workflow <path>        Start an explicit runtime file.

Options:
  --preview                    Resolve and print a saved workflow without side effects.
  --env-file <path>            1Password env file. Default: ~/.config/symphony/.env.
  --no-env-file                Do not call `op run`; use the current environment.
  --port <port>                Dashboard/API port override.
  --logs-root <path>           Logs directory override.
  --profile <name>             Select one runtime policy profile.
  --mode <mode>                Run mode: watch, drain, or issue_batch.
  --limit <count>              issue_batch dispatch limit.
  --max-agents <count>         Lower per-run agent capacity.
  --max-startups <count>       Lower per-run startup capacity.
  --no-land                    Restrict this run away from auto-land.
  --human-review-only          Route completed work to human review.
  --config-root <path>         Saved workflow config root. Default: ~/.config/symphony.
  --save <lowercase-slug>      Save a newly built workflow; collisions fail.
  --yes                        Skip the start confirmation.
  --skip-build                 Do not rebuild elixir/bin/symphony before launch.
  -h, --help                   Show this help.

Environment:
  SYMPHONY_HOME                Symphony Elixir dir. Default: <repo>/elixir.
  SYMPHONY_ENV_FILE            Default env file path.
  SYMPHONY_SKIP_BUILD=1        Same as --skip-build.

The launcher loads ~/.config/symphony/.env through 1Password CLI unless
--no-env-file is passed. Saved-workflow previews do not require that file.
USAGE
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 2
}

expand_path() {
  case "${1:-}" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${1#~/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

absolute_path() {
  case "${1:-}" in
    "") printf '\n' ;;
    /*) printf '%s\n' "$1" ;;
    *) printf '%s/%s\n' "$PWD" "$1" ;;
  esac
}

require_value() {
  local flag="$1"
  local value="${2:-}"

  [[ -n "$value" ]] || die "$flag requires a value"
}

env_file_value() {
  local file="$1"
  local key="$2"
  local line value

  [[ -f "$file" ]] || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    [[ "$line" == "$key="* ]] || continue

    value="${line#*=}"
    value="${value%$'\r'}"
    value="${value#\"}"
    value="${value%\"}"
    value="${value#\'}"
    value="${value%\'}"
    printf '%s\n' "$value"
    return 0
  done <"$file"

  return 1
}

resolve_repo_root() {
  local source="${BASH_SOURCE[0]}"
  local dir

  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    [[ "$source" = /* ]] || source="$dir/$source"
  done

  cd -P "$(dirname "$source")/.." >/dev/null 2>&1 && pwd
}

print_command() {
  local arg

  for arg in "$@"; do
    printf '%q ' "$arg"
  done

  printf '\n'
}

run_elixir() {
  local repo_root="$1"
  shift

  local symphony_home="${SYMPHONY_HOME:-"$repo_root/elixir"}"
  local workflow="${SYMPHONY_WORKFLOW:-}"
  local port="${SYMPHONY_PORT:-}"
  local logs_root="${SYMPHONY_LOGS_ROOT:-"$symphony_home/log"}"
  local profile="${SYMPHONY_PROFILE:-}"
  local args

  [[ -n "$workflow" ]] || die "SYMPHONY_WORKFLOW is required"
  [[ -f "$workflow" ]] || die "runtime setup file not found: $workflow"
  [[ -d "$symphony_home" ]] || die "SYMPHONY_HOME does not exist: $symphony_home"

  export PATH="/opt/homebrew/bin:/usr/local/bin:${HOME}/.nix-profile/bin:${HOME}/.local/bin:${HOME}/.bun/bin:/nix/var/nix/profiles/default/bin:${PATH}"

  command -v mise >/dev/null 2>&1 || {
    printf 'error: mise not found on PATH\n' >&2
    printf 'hint: install mise, then rerun symphony\n' >&2
    exit 127
  }

  cd "$symphony_home"

  if [[ "${SYMPHONY_SKIP_BUILD:-0}" != "1" ]]; then
    if [[ ! -d deps ]]; then
      mise exec -- mix setup
    fi

    mise exec -- mix escript.build
  elif [[ ! -x ./bin/symphony ]]; then
    printf 'error: %s/bin/symphony is missing\n' "$symphony_home" >&2
    printf 'hint: rerun without --skip-build so the launcher can build it\n' >&2
    exit 127
  fi

  args=(run --workflow "$workflow" --logs-root "$logs_root")

  if [[ -n "$port" ]]; then
    args+=(--port "$port")
  fi

  if [[ -n "$profile" ]]; then
    args+=(--profile "$profile")
  fi

  exec mise exec -- ./bin/symphony "${args[@]}" "$@"
}

prepare_elixir_cli_environment() {
  local symphony_home="$1"

  [[ -d "$symphony_home" ]] || die "SYMPHONY_HOME does not exist: $symphony_home"

  export PATH="/opt/homebrew/bin:/usr/local/bin:${HOME}/.nix-profile/bin:${HOME}/.local/bin:${HOME}/.bun/bin:/nix/var/nix/profiles/default/bin:${PATH}"

  command -v mise >/dev/null 2>&1 || {
    printf 'error: mise not found on PATH\n' >&2
    printf 'hint: install mise, then rerun symphony\n' >&2
    exit 127
  }

  cd "$symphony_home"
}

prepare_elixir_cli() {
  local symphony_home="$1"

  prepare_elixir_cli_environment "$symphony_home"

  if [[ "${SYMPHONY_SKIP_BUILD:-0}" != "1" ]]; then
    if [[ ! -d deps ]]; then
      mise exec -- mix setup
    fi

    mise exec -- mix escript.build
  elif [[ ! -x ./bin/symphony ]]; then
    printf 'error: %s/bin/symphony is missing\n' "$symphony_home" >&2
    printf 'hint: rerun without SYMPHONY_SKIP_BUILD=1 so the launcher can build it\n' >&2
    exit 127
  fi
}

prepare_read_only_elixir_cli() {
  local symphony_home="$1"

  prepare_elixir_cli_environment "$symphony_home"

  if [[ ! -x ./bin/symphony ]]; then
    printf 'error: %s/bin/symphony is missing\n' "$symphony_home" >&2
    printf 'hint: build it explicitly with: cd %s && mise exec -- mix escript.build\n' "$symphony_home" >&2
    exit 127
  fi
}

run_workflow_cli() {
  local repo_root="$1"
  shift

  local symphony_home="${SYMPHONY_HOME:-"$repo_root/elixir"}"

  prepare_elixir_cli "$symphony_home"

  exec mise exec -- ./bin/symphony "$@"
}

run_list_cli() {
  local repo_root="$1"
  shift

  local symphony_home="${SYMPHONY_HOME:-"$repo_root/elixir"}"
  local caller_root="$PWD"
  local args=(list)
  local arg value

  while [[ $# -gt 0 ]]; do
    arg="$1"

    case "$arg" in
      --repo|--config-root)
        require_value "$arg" "${2:-}"
        value="$(expand_path "$2")"
        args+=("$arg" "$(absolute_path "$value")")
        shift 2
        ;;
      --no-env-file)
        shift
        ;;
      --skip-build)
        export SYMPHONY_SKIP_BUILD=1
        shift
        ;;
      *)
        args+=("$arg")
        shift
        ;;
    esac
  done

  symphony_home="$(expand_path "$symphony_home")"
  symphony_home="$(absolute_path "$symphony_home")"

  prepare_read_only_elixir_cli "$symphony_home"

  exec env "SYMPHONY_HOME=$symphony_home" "SYMPHONY_RUN_REPO_ROOT=$caller_root" mise exec -- ./bin/symphony "${args[@]}"
}

run_saved_setup_cli() {
  local repo_root="$1"
  shift

  local symphony_home="${SYMPHONY_HOME:-"$repo_root/elixir"}"
  local env_file="${SYMPHONY_ENV_FILE:-"$HOME/.config/symphony/.env"}"
  local caller_root="$PWD"
  local use_env_file=1
  local escript_args=(run --i-understand-that-this-will-be-running-without-the-usual-guardrails)
  local env_optional=0
  local arg

  while [[ $# -gt 0 ]]; do
    arg="$1"

    case "$arg" in
      --env-file)
        require_value "$arg" "${2:-}"
        env_file="$2"
        shift 2
        ;;
      --no-env-file)
        use_env_file=0
        shift
        ;;
      --preview|--picker)
        env_optional=1
        escript_args+=("$1")
        shift
        ;;
      --skip-build)
        export SYMPHONY_SKIP_BUILD=1
        shift
        ;;
      *)
        escript_args+=("$1")
        shift
        ;;
    esac
  done

  symphony_home="$(expand_path "$symphony_home")"
  env_file="$(expand_path "$env_file")"
  symphony_home="$(absolute_path "$symphony_home")"
  env_file="$(absolute_path "$env_file")"

  if [[ "$use_env_file" == "1" && ! -f "$env_file" && "$env_optional" == "1" ]]; then
    use_env_file=0
  fi

  prepare_elixir_cli "$symphony_home"

  local cmd

  if [[ "$use_env_file" == "1" ]]; then
    [[ -f "$env_file" ]] || die "env file not found: $env_file; copy symphony.env.example there or pass --no-env-file"
    command -v op >/dev/null 2>&1 || {
      printf 'error: op not found on PATH\n' >&2
      printf 'hint: install the 1Password CLI or pass --no-env-file\n' >&2
      exit 127
    }

    cmd=(env "SYMPHONY_HOME=$symphony_home" "SYMPHONY_RUN_REPO_ROOT=$caller_root" op run --env-file "$env_file" -- mise exec -- ./bin/symphony "${escript_args[@]}")
  else
    cmd=(env "SYMPHONY_HOME=$symphony_home" "SYMPHONY_RUN_REPO_ROOT=$caller_root" mise exec -- ./bin/symphony "${escript_args[@]}")
  fi

  exec "${cmd[@]}"
}

main() {
  local repo_root
  repo_root="$(resolve_repo_root)"

  if [[ "${1:-}" == "__run" ]]; then
    shift
    run_elixir "$repo_root" "$@"
  fi

  if [[ "${1:-}" == "workflow" || "${1:-}" == "setup" ]]; then
    run_workflow_cli "$repo_root" "$@"
  fi

  if [[ "${1:-}" == "list" ]]; then
    shift
    run_list_cli "$repo_root" "$@"
  fi

  if [[ "${1:-}" == "run" ]]; then
    shift
    run_saved_setup_cli "$repo_root" "$@"
  fi

  if [[ $# -eq 0 && -f symphony.yml ]]; then
    run_saved_setup_cli "$repo_root" --picker --repo "$PWD"
  fi

  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  die "unknown command: $1; use setup, list, or run"
}

main "$@"
