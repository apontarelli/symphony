# Copy to ~/.config/symphony/.env and replace the 1Password secret references.
LINEAR_API_KEY=op://<vault>/<item>/<field>

# Optional: if your workflow filters to one assignee.
# LINEAR_ASSIGNEE=op://<vault>/<item>/<field>

# Optional non-secret defaults. The repo-owned launcher infers these when omitted.
# SYMPHONY_DEV_ROOT=/Users/<you>/dev
# SYMPHONY_HOME=/Users/<you>/dev/symphony/elixir
# SYMPHONY_LOGS_ROOT=/Users/<you>/dev/symphony/elixir/log

# Optional direct server port. Leave unset to use the launcher default.
# SYMPHONY_PORT=4000
